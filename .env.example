# Copy to .env and fill in your values. Never commit .env.

# AWS region your bucket lives in, e.g. us-east-1
AWS_REGION=us-east-1

# The private S3 bucket that holds your video files
S3_BUCKET=my-wachin-tv-videos

# Optional key prefix if your videos live under a "folder", e.g. videos/
S3_PREFIX=

# Credentials. You can leave these blank if the machine already has AWS
# credentials configured (env, ~/.aws/credentials, or an IAM role).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# How long (seconds) a generated stream URL stays valid
URL_TTL_SECONDS=3600

# Port for the web server
PORT=3000

# --- Database (Railway Postgres) ---
# Locally use Railway's DATABASE_PUBLIC_URL; on Railway the internal
# DATABASE_URL is injected automatically for the deployed service.
DATABASE_URL=postgresql://user:pass@host:port/railway

# --- Auth ---
# Public base URL of the app, used to build magic-link URLs.
# Local: http://localhost:3000  ·  Prod: your Railway domain (https://...)
APP_URL=http://localhost:3000
SESSION_TTL_DAYS=30
MAGIC_LINK_TTL_MINUTES=15

# --- Email (Mailtrap SMTP) ---
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=wachin.tv <no-reply@wachin.tv>
